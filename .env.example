# ResumRank AI — Environment Variables
# No API key needed. Copy this to .env and set SECRET_KEY for production.

# App Environment
APP_ENV=production

# Flask secret key (required in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# Server port (Heroku sets this automatically via PORT env var)
PORT=5000

# Note: No GEMINI_API_KEY or API keys needed. App uses local spaCy NLP.
